{
  "name": "codex-autoresearch",
  "version": "0.1.0",
  "description": "Unified Codex long-task runner with CLI, skills, and MCP entrypoints.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/congwa/codex-autoresearch.git"
  },
  "homepage": "https://github.com/congwa/codex-autoresearch#readme",
  "bugs": {
    "url": "https://github.com/congwa/codex-autoresearch/issues"
  },
  "bin": {
    "codex-autoresearch": "./dist/src/cli.js"
  },
  "exports": {
    ".": "./dist/src/index.js",
